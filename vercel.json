{
    "crons": [
        {
            "path": "/api/texas/cron/refresh",
            "schedule": "0 0 1 * *"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.py"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}