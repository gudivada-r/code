default_platform(:ios)

platform :ios do
  desc "Push a new release to TestFlight (Generic Factory)"
  lane :release do |options|
    
    # 1. Config Loading (From Env or Args)
    team_id = ENV["APPLE_TEAM_ID"]
    bundle_id = ENV["APP_BUNDLE_ID"] || "com.example.navigator"
    
    # 2. Setup CI
    setup_ci
    
    # 3. Code Signing (Manual/Inject)
    update_code_signing_settings(
      use_automatic_signing: false,
      targets: ["App"],
      path: "App/App.xcodeproj",
      bundle_identifier: bundle_id,
      team_id: team_id,
      code_sign_identity: "Apple Distribution"
    )

    # 4. Build
    build_app(
      workspace: "App/App.xcworkspace",
      scheme: "App",
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates TARGETED_DEVICE_FAMILY=1" 
    )

    # 5. Upload
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      api_key: api_key # Defined globally or via ENV
    )
  end
end
