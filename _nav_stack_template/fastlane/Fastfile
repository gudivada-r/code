default_platform(:ios)

platform :ios do
  desc "The Navigator Mobile Factory: Build and Deploy generically"
  lane :release do
    # 0. Setup (ensure clean state)
    ensure_git_status_clean
    
    # 1. Update Project Settings Dynamically
    # This enables the "White Label" factory model by injecting IDs for new clients
    update_app_identifier(
      xcodeproj: "App/App.xcodeproj",
      plist_path: "App/App/Info.plist",
      app_identifier: ENV["APP_BUNDLE_ID"] # e.g. com.healthapps.navigator
    )
    
    update_code_signing_settings(
      use_automatic_signing: true,
      path: "App/App.xcodeproj",
      team_id: ENV["APPLE_TEAM_ID"],
      bundle_identifier: ENV["APP_BUNDLE_ID"]
    )

    # 2. Increment Build Number
    increment_build_number(xcodeproj: "App/App.xcodeproj")

    # 3. Build the IPA
    build_app(scheme: "App")

    # 4. Upload to TestFlight
    # api_key is handled via App Store Connect API Key (json)
    upload_to_testflight(
      skip_waiting_for_build_processing: true
    )
  end
end
